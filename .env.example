# =====================================================================
# SUPABASE
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# =====================================================================
# FREE / OPEN ROUTING & GEOCODING APIS
# =====================================================================
# Nominatim — geocoding. Free, but requires a valid User-Agent (set in code).
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org

# OSRM — free public demo server for road routing (rate-limited; self-host for production)
NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org

# OpenRouteService — optional, free tier with API key (https://openrouteservice.org/dev/#/signup)
ORS_API_KEY=

# =====================================================================
# OPTIONAL: FREE/LOCAL LLM FOR CHAT (deterministic logic is default fallback)
# Leave blank to use rule-based deterministic chat engine only.
# =====================================================================
OPTIONAL_LLM_API_URL=
OPTIONAL_LLM_API_KEY=

# =====================================================================
# APP CONFIG
# =====================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="TN Transport Enquiry"
